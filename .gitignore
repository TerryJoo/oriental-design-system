# Storybook test-runner artifacts. The JSONL log is regenerated by
# `npm run test-storybook:ci` on every run; only the rendered
# `wave6a-a11y-baseline.md` is checked in deliberately.
claudedocs/wave6a-a11y-violations.jsonl

# Playwright per-run report dirs (test-runner uses jest-junit; nothing
# is written to disk by default, but if `--junit` is enabled the output
# file lives at the repo root).
test-storybook-results/
playwright-report/

# Visual regression baselines — committed under `__visual_snapshots__/`.
# Only the `*.png` baselines are tracked; per-run diff artifacts written
# next to a failure (`*.actual.png`) are NOT, since they're regenerated
# on every failed run.
__visual_snapshots__/*.actual.png
